<!DOCTYPE html>
<html lang="tk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Berdi_B - Premium Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #020617;
            --card-bg: rgba(30, 41, 59, 0.5);
            --text-main: #ffffff;
            --text-sub: #94a3b8;
            --accent: #38bdf8;
            --money-grad: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
            --kakajan-grad: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            --magazyn-grad: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%);
            --yusup-grad: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
            --glass-border: rgba(255, 255, 255, 0.08);
            --shadow-lg: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
        }

        [data-theme="light"] {
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-sub: #64748b;
            --glass-border: rgba(0, 0, 0, 0.05);
        }

        * { box-sizing: border-box; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg-color); 
            color: var(--text-main); 
            margin: 0; padding: 0;
            overflow-x: hidden;
        }

        .center-logo {
            position: fixed; top: 15px; left: 50%; transform: translateX(-50%);
            z-index: 1002; font-weight: 900; font-size: 18px; letter-spacing: 3px;
            color: var(--text-main); text-shadow: 0 0 15px rgba(56, 189, 248, 0.5);
            background: rgba(255, 255, 255, 0.03); padding: 5px 15px;
            border-radius: 50px; backdrop-filter: blur(5px);
            border: 1px solid var(--glass-border); pointer-events: none;
            transition: 0.3s ease;
        }

        #loginPage, .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--bg-color); display: flex; align-items: center; justify-content: center;
            z-index: 9999; padding: 20px;
        }
        
        .modal-overlay { background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); z-index: 10000; display: none; }
        .login-card, .modal-card { width: 100%; max-width: 350px; text-align: center; animation: fadeIn 0.4s ease; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        header { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 10px 20px; position: fixed; top: 0; width: 100%; z-index: 100;
            backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
            max-width: 500px; left: 50%; transform: translateX(-50%);
            border-bottom: 1px solid var(--glass-border);
        }

        .header-controls { display: flex; align-items: center; gap: 15px; }
        .icon-btn { 
            font-size: 18px; cursor: pointer; opacity: 0.8; 
            width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;
            background: rgba(255,255,255,0.05); border-radius: 10px;
        }

        .sidebar {
            position: fixed; top: 10px; left: -110%; width: 85%; max-width: 320px; height: calc(100% - 20px);
            background: rgba(15, 23, 42, 0.98); z-index: 1001; padding: 40px 25px;
            border-radius: 25px; backdrop-filter: blur(40px); border: 1px solid var(--glass-border);
            transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .sidebar.active { left: 10px; }
        
        .nav-link {
            padding: 18px; margin-bottom: 12px; border-radius: 18px;
            cursor: pointer; font-weight: 700; color: var(--text-sub);
            background: rgba(255,255,255,0.03);
        }
        .nav-link.active { color: #fff; background: var(--money-grad); }

        .container { max-width: 500px; margin: auto; padding: 90px 18px 40px 18px; }

        .glass-card { 
            background: var(--card-bg); border-radius: 24px; padding: 22px; 
            border: 1px solid var(--glass-border); margin-bottom: 20px;
            box-shadow: var(--shadow-lg);
        }

        .main-summary { 
            background: var(--money-grad); color: white; text-align: center; 
            padding: 30px 20px; border-radius: 24px;
        }
        .yusup-summary { background: var(--yusup-grad); }

        .total-val { font-size: 34px; font-weight: 900; margin: 10px 0; letter-spacing: -1px; }

        .stat-card { padding: 15px; border-radius: 20px; color: white; text-align: center; }
        .stat-label { font-size: 10px; font-weight: 800; opacity: 0.8; letter-spacing: 1px; }
        .stat-amount { font-size: 18px; font-weight: 700; margin-top: 5px; }
        
        input { 
            width: 100%; padding: 16px; border-radius: 16px; border: 1px solid var(--glass-border);
            background: rgba(255,255,255,0.05); color: var(--text-main); font-size: 16px;
            outline: none; margin-bottom: 12px;
        }

        .btn-primary { 
            width: 100%; padding: 18px; border-radius: 16px; border: none;
            background: #fff; color: #000; font-size: 16px; font-weight: 800; cursor: pointer;
        }

        .item-card { display: flex; justify-content: space-between; align-items: center; position: relative; }
        .item-info { flex: 1; }
        .date-label { font-size: 10px; color: var(--text-sub); margin-top: 4px; display: block; opacity: 0.7; }
        
        .qty-control { display: flex; align-items: center; gap: 12px; background: rgba(0,0,0,0.2); padding: 6px 10px; border-radius: 14px; }
        .qty-btn { width: 32px; height: 32px; border-radius: 10px; border: none; background: rgba(255,255,255,0.1); color: #fff; cursor: pointer; }

        .overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); backdrop-filter: blur(10px); display:none; z-index: 1000; }
        .overlay.active { display: block; }
    </style>
</head>
<body>

<div class="center-logo" id="topLogo" style="display: none;">BERDI_B</div>

<div id="loginPage">
    <div class="login-card glass-card">
        <h1 style="letter-spacing: 4px; margin-bottom: 30px;">BERDI_B</h1>
        <input type="text" id="userInp" placeholder="Ulanyjy ady">
        <input type="password" id="passInp" placeholder="Parol" inputmode="numeric">
        <button class="btn-primary" onclick="checkLogin()">Giriş Et</button>
        <p id="loginError" style="color: #f87171; font-size: 13px; display: none; margin-top: 15px;">Maglumatlar ýalňyş!</p>
    </div>
</div>

<div class="modal-overlay" id="yusupModal">
    <div class="modal-card glass-card">
        <h3 style="margin-bottom: 20px;">Yusup Parfume Giriş</h3>
        <input type="password" id="yusupPassInput" placeholder="Sanly paroly giriziň" inputmode="numeric">
        <div style="display: flex; gap: 10px;">
            <button class="btn-primary" onclick="closeYusupModal()" style="background: rgba(255,255,255,0.1); color: white;">Yza</button>
            <button class="btn-primary" onclick="verifyYusupPass()" style="background: var(--accent); color: white;">Giriş</button>
        </div>
    </div>
</div>

<div id="mainApp" style="display:none;">
    <header>
        <div onclick="toggleMenu()" class="icon-btn">☰</div>
        <div class="header-controls">
            <div onclick="toggleSearch()" class="icon-btn">🔍</div>
            <div onclick="toggleTheme()" class="icon-btn">🌓</div>
        </div>
    </header>

    <div class="overlay" id="overlay" onclick="toggleMenu()"></div>

    <div class="sidebar" id="sidebar">
        <h2 style="font-size: 28px; color: var(--accent); margin-bottom: 30px;">BERDI_B</h2>
        <div class="nav-link active" id="nav-home" onclick="switchPage('berdi')">🏠 Esasy Sahypa</div>
        <div class="nav-link" id="nav-yusup" onclick="openYusupModal()">💎 Yusup Parfume</div>
        <div class="nav-link" id="nav-export" onclick="switchPage('export')">📊 Maglumatlar</div>
        <div class="nav-link" onclick="location.reload()" style="margin-top: 40px; color: #f87171;">🚪 Çykyş Et</div>
    </div>

    <div class="container">
        <input type="text" id="searchBox" style="display:none;" placeholder="Harydy gözle..." oninput="updateUI()">
        
        <div id="homeUI">
            <div class="glass-card main-summary">
                <span style="font-size: 11px; font-weight: 800; opacity: 0.8; letter-spacing: 2px;">JEMI PEÝDA</span>
                <div class="total-val" id="mainVal">0.00 TMT</div>
                <div style="display: flex; justify-content: center; gap: 20px; font-size: 13px;">
                    <span>Sany: <b id="tCountH">0</b></span>
                    <span>Çykdaýjy: <b id="tCostH">0.00</b></span>
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                <div class="stat-card" style="background: var(--kakajan-grad);">
                    <span class="stat-label">KAKAJAN</span>
                    <div id="kProfit" class="stat-amount">0.00</div>
                </div>
                <div class="stat-card" style="background: var(--magazyn-grad);">
                    <span class="stat-label">MAGAZYN</span>
                    <div id="mProfit" class="stat-amount">0.00</div>
                </div>
            </div>
        </div>

        <div id="yusupUI" style="display: none;">
            <div class="glass-card main-summary yusup-summary">
                <span style="font-size: 11px; font-weight: 800; opacity: 0.8; letter-spacing: 2px;">JEMI PEÝDA</span>
                <div class="total-val" id="yProfitMain">0.00 TMT</div>
                <div style="display: flex; justify-content: center; gap: 20px; font-size: 13px;">
                    <span>Sany: <b id="yCountH">0</b></span>
                    <span>Çykdaýjy: <b id="yCostH">0.00</b></span>
                </div>
            </div>
        </div>

        <div id="exportUI" style="display: none;">
            <h2 style="margin-bottom: 20px;">Hasabatlar</h2>
            <div class="export-btn" onclick="exportToCSV()" style="padding: 20px; background: var(--card-bg); border-radius: 20px; cursor: pointer; margin-bottom: 15px; border: 1px solid var(--glass-border);">
                <b>📄 CSV (Excel) Ýükle</b>
            </div>
            <div class="export-btn" onclick="clearData()" style="padding: 20px; background: var(--card-bg); border-radius: 20px; cursor: pointer; margin-bottom: 15px; border: 1px solid #f43f5e; color: #f43f5e;">
                <b>🗑️ Ählisini Poz</b>
            </div>
        </div>

        <div class="glass-card" id="inputSection">
            <input type="text" id="name" placeholder="Harydyň ady">
            <div style="display: flex; gap: 10px;">
                <input type="number" id="count" placeholder="Sany">
                <input type="number" id="price" placeholder="Bahasy">
            </div>
            <input type="number" id="profit" placeholder="Peýda (1 sany)">
            <button class="btn-primary" onclick="addItem()" style="background: var(--accent); color: white;">Goş</button>
        </div>

        <div id="itemList"></div>
    </div>
</div>

<script>
    let current = 'berdi';
    let data = { 
        berdi: JSON.parse(localStorage.getItem('berdi_data')) || [], 
        yusup: JSON.parse(localStorage.getItem('yusup_data')) || [] 
    };

    function checkLogin() {
        if(document.getElementById('passInp').value === "915091") {
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('mainApp').style.display = 'block';
            document.getElementById('topLogo').style.display = 'block';
            updateUI();
        } else { document.getElementById('loginError').style.display = 'block'; }
    }

    function openYusupModal() {
        toggleMenu();
        document.getElementById('yusupModal').style.display = 'flex';
    }

    function closeYusupModal() {
        document.getElementById('yusupModal').style.display = 'none';
        document.getElementById('yusupPassInput').value = '';
    }

    function verifyYusupPass() {
        if(document.getElementById('yusupPassInput').value === "915091") {
            closeYusupModal();
            switchPage('yusup');
        } else { alert("Parol ýalňyş!"); }
    }

    function toggleMenu() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');
        const topLogo = document.getElementById('topLogo');

        sidebar.classList.toggle('active');
        overlay.classList.toggle('active');

        if (sidebar.classList.contains('active')) {
            topLogo.style.opacity = '0';
        } else {
            topLogo.style.opacity = '1';
        }
    }

    function switchPage(p) {
        const sidebar = document.getElementById('sidebar');
        if (sidebar.classList.contains('active')) toggleMenu();

        if(p !== 'export') current = p;
        document.getElementById('nav-home').classList.toggle('active', p === 'berdi');
        document.getElementById('nav-yusup').classList.toggle('active', p === 'yusup');
        document.getElementById('nav-export').classList.toggle('active', p === 'export');
        
        document.getElementById('homeUI').style.display = (p === 'berdi' ? 'block' : 'none');
        document.getElementById('yusupUI').style.display = (p === 'yusup' ? 'block' : 'none');
        document.getElementById('exportUI').style.display = (p === 'export' ? 'block' : 'none');
        document.getElementById('inputSection').style.display = (p === 'export' ? 'none' : 'block');
        document.getElementById('itemList').style.display = (p === 'export' ? 'none' : 'block');
        
        if(p !== 'export') updateUI();
    }

    function updateUI() {
        const list = document.getElementById('itemList');
        const searchTerm = document.getElementById('searchBox').value.toLowerCase();
        list.innerHTML = '';
        
        let totalCount = 0, totalCost = 0, totalProfit = 0;
        
        // Täze goşulan harytlar iň ýokarda görüner ýaly tersine aýlaýarys (optional)
        const displayData = [...data[current]].reverse();

        data[current].forEach((item, i) => {
            if(item.name.toLowerCase().includes(searchTerm)) {
                let count = Number(item.count);
                let price = Number(item.price);
                let profit = Number(item.profit);
                // Köne maglumatlarda sene ýok bolsa boş görkezer
                let dateStr = item.date ? item.date : "";

                totalCount += count;
                totalCost += (price * count);
                totalProfit += (profit * count);

                const div = document.createElement('div');
                div.className = 'glass-card item-card';
                div.innerHTML = `
                    <div class="item-info">
                        <b>${item.name}</b><br>
                        <small>${price} TMT | Peýda: +${(profit * count).toFixed(2)}</small>
                        <span class="date-label">${dateStr}</span>
                        <small onclick="deleteItem(${i})" style="color:#f43f5e;cursor:pointer; display:inline-block; margin-top:5px;">Poz</small>
                    </div>
                    <div class="qty-control">
                        <button class="qty-btn" onclick="qty(${i},-1)">-</button>
                        <b>${count}</b>
                        <button class="qty-btn" onclick="qty(${i},1)">+</button>
                    </div>`;
                list.appendChild(div);
            }
        });

        if(current === 'berdi') {
            document.getElementById('mainVal').innerText = totalProfit.toFixed(2) + " TMT";
            document.getElementById('kProfit').innerText = (totalProfit / 2).toFixed(2) + " TMT";
            document.getElementById('mProfit').innerText = (totalProfit / 2).toFixed(2) + " TMT";
            document.getElementById('tCountH').innerText = totalCount;
            document.getElementById('tCostH').innerText = totalCost.toFixed(2) + " TMT";
        } else if(current === 'yusup') {
            document.getElementById('yProfitMain').innerText = totalProfit.toFixed(2) + " TMT";
            document.getElementById('yCountH').innerText = totalCount;
            document.getElementById('yCostH').innerText = totalCost.toFixed(2) + " TMT";
        }

        localStorage.setItem(current + '_data', JSON.stringify(data[current]));
    }

    function addItem() {
        const n = document.getElementById('name').value;
        const c = parseFloat(document.getElementById('count').value);
        const p = parseFloat(document.getElementById('price').value);
        const pr = parseFloat(document.getElementById('profit').value) || 0;

        // Häzirki wagty we senäni alýarys
        const now = new Date();
        const dateString = now.toLocaleDateString('tk-TM') + " " + now.toLocaleTimeString('tk-TM', {hour: '2-digit', minute:'2-digit'});

        if(n && !isNaN(c) && !isNaN(p)) { 
            data[current].push({ 
                name: n, 
                count: c, 
                price: p, 
                profit: pr,
                date: dateString // Senäni saklaýarys
            }); 
            updateUI(); 
            ['name', 'count', 'price', 'profit'].forEach(id => document.getElementById(id).value = ''); 
        }
    }

    function qty(i, d) { if(data[current][i].count + d >= 0) { data[current][i].count += d; updateUI(); } }
    function deleteItem(i) { if(confirm("Pozmaly?")) { data[current].splice(i, 1); updateUI(); } }
    
    function toggleSearch() {
        const sb = document.getElementById('searchBox');
        sb.style.display = (sb.style.display === 'block') ? 'none' : 'block';
    }

    function toggleTheme() {
        const t = document.body.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        document.body.setAttribute('data-theme', t);
    }

    function exportToCSV() {
        let csvContent = "data:text/csv;charset=utf-8,Haryt,Sany,Bahasy,Peyda,Sene\n";
        data[current].forEach(i => csvContent += `${i.name},${i.count},${i.price},${(i.profit*i.count).toFixed(2)},${i.date || ''}\n`);
        const link = document.createElement("a");
        link.setAttribute("href", encodeURI(csvContent));
        link.setAttribute("download", `${current}_hasabat.csv`);
        link.click();
    }

    function clearData() { if(confirm("Ählisini pozmak isleýärsiňizmi?")) { localStorage.clear(); location.reload(); } }
</script>
</body>
</html>
